<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings_title"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- アカウント（ログイン・ログアウト） -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_account"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvAccountStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_not_signed_in"
                android:textSize="14sp"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLoginLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_sign_in"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- アップロード先（共有ドライブ） -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/settings_drive_folder"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/label_folder_id"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFolderId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_pick_folder"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 監視するフォルダ（標準カメラの保存先） -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/settings_watch_folder"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvWatchFolderDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_watch_folder_desc"
                android:textSize="14sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvWatchFolderCurrent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_watch_folder_none"
                android:textSize="14sp"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectWatchFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_select_watch_folder"
                style="@style/Widget.Material3.Button.TonalButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/btn_save" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
